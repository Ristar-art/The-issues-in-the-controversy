rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Images: anyone can read, only authenticated users can upload
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Audio: anyone can read, only authenticated users can upload
    match /audio/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }

    // Video: anyone can read, only authenticated users can upload
    match /video/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 200 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
    }
  }
}
