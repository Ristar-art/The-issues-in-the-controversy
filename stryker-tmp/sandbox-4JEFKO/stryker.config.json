{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Stryker mutation testing config — runs vitest against mutated source.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.{ts,js}",
    "!src/**/*.test.{ts,js}",
    "!src/**/*.spec.{ts,js}",
    "!src/**/*.d.ts",
    "!src/app.html",
    "!src/stories/**"
  ],
  "ignorePatterns": [
    ".svelte-kit",
    ".vercel",
    "build",
    "static",
    "node_modules",
    "reports",
    "stryker-tmp"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "tempDirName": "stryker-tmp",
  "cleanTempDir": true,
  "timeoutMS": 60000,
  "concurrency": 4
}
